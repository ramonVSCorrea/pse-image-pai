                     đđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđđPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP                     đđđđđđđđđđđđđđđđđđđđđđđđđđđđđđPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP                     đđđđđđđđđđđđđđđđđđđđđđđđđđPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP                     đđđđđđđđđđđđđđđđđđđ                     đ                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             